---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marty Supreme Edition">
  <main class="min-h-screen bg-surface">
    <section class="grid place-items-center min-h-screen px-8">
      <div class="max-w-3xl text-center">
        <p class="text-label font-epilogue text-on-surface-variant uppercase tracking-[0.15em] mb-4">
          Hi, my name is
        </p>
        <h1 class="font-epilogue text-display-md md:text-display-xl font-black uppercase tracking-[-0.02em] text-on-surface leading-none mb-6">
          Your Name
        </h1>
        <p class="font-epilogue text-body-lg text-on-surface-variant max-w-xl mx-auto mb-10">
          I build things for the web. Focused on creating clean, performant
          experiences with modern technologies.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a href="#projects" class="font-epilogue text-label uppercase tracking-[0.1em] bg-primary text-on-primary px-8 py-4 rounded-none no-underline inline-block transition-opacity duration-200 hover:opacity-80">
            View my work
          </a>
          <a href="#contact" class="font-epilogue text-label uppercase tracking-[0.1em] text-on-surface border border-outline-variant px-8 py-4 rounded-none no-underline inline-block transition-all duration-200 hover:border-outline hover:bg-surface-container-low">
            Get in touch
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
